# Application
APP_ENV=development
APP_NAME=VitalAI
APP_VERSION=0.1.0
SYNTHETIC_ONLY=true

# Database
DATABASE_URL=postgresql+asyncpg://vitalai:vitalai@db:5432/vitalai

# Auth
JWT_SECRET_KEY=change-me-generate-with-secrets-token_urlsafe
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM provider switch
# Dev: ollama   Staging/Prod: bedrock
LLM_PROVIDER=ollama
LLM_MODEL=gemma2:2b
OLLAMA_BASE_URL=http://ollama:11434

# Bedrock (used only when LLM_PROVIDER=bedrock)
AWS_REGION=ap-southeast-2
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Cache
REDIS_URL=redis://redis:6379/0

# Object storage (MinIO)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Embeddings  (nomic dev | bedrock prod)
EMBEDDING_PROVIDER=nomic
EMBEDDING_MODEL=nomic-embed-text
